<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="368.0" prefWidth="585.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.CreateEventController">
   <children>
      <Label layoutX="43.0" layoutY="31.0" text="CREATE NEW EVENT">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Button layoutX="510.0" layoutY="32.0" mnemonicParsing="false" onAction="#backButtonONACTION" prefHeight="26.0" prefWidth="61.0" text="Back" />
      <Label layoutX="43.0" layoutY="101.0" text="Event ID:" />
      <TextField fx:id="idtextfield" layoutX="150.0" layoutY="97.0" promptText="Enter event ID" />
      <Label layoutX="43.0" layoutY="136.0" text="Event Type:" />
      <ComboBox fx:id="typeCombobox" layoutX="150.0" layoutY="132.0" prefWidth="150.0" />
      <Label layoutX="43.0" layoutY="171.0" text="Event Date:" />
      <DatePicker fx:id="date" layoutX="150.0" layoutY="166.0" prefHeight="26.0" prefWidth="164.0" />
      <Label layoutX="43.0" layoutY="207.0" text="Event Time:" />
      <TextField fx:id="timetextfield" layoutX="150.0" layoutY="203.0" promptText="Enter event Time" />
      <Label layoutX="45.0" layoutY="243.0" text="Event Venue" />
      <ComboBox fx:id="VanueCombobox" layoutX="149.0" layoutY="239.0" prefWidth="150.0" />
      <Label layoutX="43.0" layoutY="293.0" text="Event Description" />
      <TextArea fx:id="descriptiontextfield" layoutX="150.0" layoutY="277.0" prefHeight="50.0" prefWidth="150.0" />
      <Button layoutX="388.0" layoutY="314.0" mnemonicParsing="false" onAction="#saveButtonONACTION" prefHeight="26.0" prefWidth="82.0" text="SAVE" />
      <Button layoutX="489.0" layoutY="314.0" mnemonicParsing="false" onAction="#clearButtonONACTION" prefHeight="26.0" prefWidth="82.0" text="CLEAR " />
   </children>
</AnchorPane>
