<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerDashboardController">
    <children>
        <Label layoutX="215.0" layoutY="40.0" text="Player Dashboard">
            <font>
                <Font name="Arial Bold" size="26.0" />
            </font>
        </Label>

        <Label layoutX="240.0" layoutY="90.0" text="Welcome, Player!" />

        <Button layoutX="200.0" layoutY="140.0" prefWidth="250.0" prefHeight="35.0" text="View Training Schedule" onAction="#openViewTrainingSchedule" />
        <Button layoutX="200.0" layoutY="190.0" prefWidth="250.0" prefHeight="35.0" text="View Match Schedule" onAction="#openViewMatchSchedule" />
        <Button layoutX="200.0" layoutY="240.0" prefWidth="250.0" prefHeight="35.0" text="View Personal Performance" onAction="#openViewPerformance" />
        <Button layoutX="200.0" layoutY="290.0" prefWidth="250.0" prefHeight="35.0" text="Mark Attendance" onAction="#openMarkAttendance" />
        <Button layoutX="200.0" layoutY="340.0" prefWidth="250.0" prefHeight="35.0" text="Request Equipment" onAction="#openRequestEquipment" />
        <Button layoutX="200.0" layoutY="390.0" prefWidth="250.0" prefHeight="35.0" text="View Announcements" onAction="#openViewAnnouncements" />
        <Button layoutX="200.0" layoutY="440.0" prefWidth="250.0" prefHeight="35.0" text="Update Personal Profile" onAction="#openUpdateProfile" />

        <Button layoutX="530.0" layoutY="460.0" prefWidth="80.0" prefHeight="27.0" text="Logout" onAction="#logout" />
    </children>
</AnchorPane>
