<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CoachUpdateTrainingPlanController">
    <children>
        <Label layoutX="190.0" layoutY="30.0" text="Update Training Plan">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="90.0" text="Plan Title:" />
        <TextField fx:id="planTitleField" layoutX="260.0" layoutY="86.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter plan title" />

        <Label layoutX="80.0" layoutY="133.0" text="Date:" />
        <DatePicker fx:id="datePicker" layoutX="260.0" layoutY="129.0" prefWidth="280.0" />

        <Label layoutX="80.0" layoutY="176.0" text="Start Time:" />
        <TextField fx:id="startTimeField" layoutX="260.0" layoutY="172.0" prefWidth="280.0" prefHeight="26.0" promptText="e.g. 09:00 AM" />

        <Label layoutX="80.0" layoutY="219.0" text="End Time:" />
        <TextField fx:id="endTimeField" layoutX="260.0" layoutY="215.0" prefWidth="280.0" prefHeight="26.0" promptText="e.g. 11:00 AM" />

        <Label layoutX="80.0" layoutY="262.0" text="Training Type:" />
        <ComboBox fx:id="trainingTypeCombo" layoutX="260.0" layoutY="258.0" prefWidth="280.0" prefHeight="26.0" promptText="Select Training Type" />

        <Label layoutX="80.0" layoutY="305.0" text="Venue:" />
        <TextField fx:id="venueField" layoutX="260.0" layoutY="301.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter venue" />

        <Label layoutX="80.0" layoutY="348.0" text="Drills and Exercises:" />
        <TextArea fx:id="drillsArea" layoutX="260.0" layoutY="344.0" prefWidth="280.0" prefHeight="80.0" promptText="List drills and exercises" />

        <Label layoutX="80.0" layoutY="440.0" text="Notes:" />
        <TextArea fx:id="notesArea" layoutX="260.0" layoutY="436.0" prefWidth="280.0" prefHeight="70.0" promptText="Enter any notes" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="520.0" prefWidth="460.0" prefHeight="30.0" />

        <Button layoutX="260.0" layoutY="558.0" prefWidth="120.0" prefHeight="27.0" text="Update" onAction="#updatePlan" />
        <Button layoutX="400.0" layoutY="558.0" prefWidth="70.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
