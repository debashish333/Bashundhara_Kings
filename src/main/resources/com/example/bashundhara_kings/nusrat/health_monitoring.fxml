<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" prefHeight="400.0" prefWidth="600.0">

    <top>
        <Label text="Health Monitoring" style="-fx-font-size:18px; -fx-padding:10;" />
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding:10; -fx-background-color:#2c3e50;">
            <Button text="Dashboard"/>
            <Button text="Update Injury Record"/>
            <Button text="Medical History"/>
            <Button text="Fitness Evaluation"/>
            <Button text="Recovery Management"/>
            <Button text="Health Monitoring"/>
            <Button text="Medical Test Records"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10">

            <Button text="Load Health Data"/>

            <TableView>

                <columns>
                    <TableColumn text="Player ID"/>
                    <TableColumn text="Heart Rate"/>
                    <TableColumn text="Condition"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>