<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" prefHeight="400" prefWidth="600">

    <top>
        <Label text="Accountant Dashboard" style="-fx-font-size:18px; -fx-padding:10;" />
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding:10; -fx-background-color:#34495e;">
            <Button text="Dashboard"/>
            <Button text="Player Payment"/>
            <Button text="Expenses"/>
            <Button text="Salary"/>
            <Button text="Financial Report"/>
            <Button text="Budget"/>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="15">
            <Label text="Welcome Accountant" style="-fx-font-size:16px;"/>
            <Label text="Manage all financial activities here"/>
        </VBox>
    </center>

</BorderPane>