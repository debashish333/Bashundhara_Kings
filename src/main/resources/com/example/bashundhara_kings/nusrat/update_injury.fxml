<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25">

    <!-- TOP -->
    <top>
        <Label text="Update Injury Record"
               style="-fx-font-size:18px; -fx-padding:10;" />
    </top>

    <!-- LEFT MENU -->
    <left>
        <VBox spacing="10"
              style="-fx-padding:10; -fx-background-color:#2c3e50;">

            <Button text="Dashboard" prefWidth="150"/>
            <Button text="Update Injury Record" prefWidth="150"/>
            <Button text="Medical History" prefWidth="150"/>
            <Button text="Fitness Evaluation" prefWidth="150"/>
            <Button text="Recovery Management" prefWidth="150"/>
            <Button text="Health Monitoring" prefWidth="150"/>
            <Button text="Medical Test Records" prefWidth="150"/>

        </VBox>
    </left>

    <!-- CENTER FORM -->
    <center>
        <VBox alignment="CENTER" spacing="10">

            <TextField promptText="Player ID"/>
            <TextField promptText="Injury Type"/>
            <TextArea promptText="Injury Description"/>
            <DatePicker/>
            <ComboBox promptText="Status"/>
            <Button text="Save Record"/>

        </VBox>
    </center>

</BorderPane>