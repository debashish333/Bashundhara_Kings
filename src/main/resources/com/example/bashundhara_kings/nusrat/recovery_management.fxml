<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25" prefHeight="400.0" prefWidth="600.0">

    <top>
        <Label text="Recovery Management" style="-fx-font-size:18px; -fx-padding:10;" />
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding:10; -fx-background-color:#2c3e50;">
            <Button text="Dashboard"/>
            <Button text="Update Injury Record"/>
            <Button text="Medical History"/>
            <Button text="Fitness Evaluation"/>
            <Button text="Recovery Management"/>
            <Button text="Health Monitoring"/>
            <Button text="Medical Test Records"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10" alignment="CENTER">

            <Label text="Recovery Plan"/>

            <TextField promptText="Player ID"/>
            <TextArea promptText="Recovery Plan Details"/>

            <Label text="Progress"/>
            <Slider min="0" max="100"/>

            <Button text="Update Progress"/>

        </VBox>
    </center>

</BorderPane>