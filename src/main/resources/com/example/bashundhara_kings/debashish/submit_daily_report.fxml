<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainpane" prefHeight="472.0" prefWidth="565.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.debashish.SubmitDailyReportController">
   <children>
      <Label layoutX="160.0" layoutY="29.0" text="Daily Security Report">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label layoutX="47.0" layoutY="86.0" text="Guard ID:" />
      <TextField fx:id="guardIDtextfield" layoutX="139.0" layoutY="82.0" />
      <Label layoutX="47.0" layoutY="137.0" text="Report Date:" />
      <DatePicker fx:id="dob" layoutX="139.0" layoutY="133.0" />
      <Label layoutX="47.0" layoutY="176.0" text="Shift Time:" />
      <ComboBox fx:id="shiftTimeCombobox" layoutX="136.0" layoutY="172.0" prefWidth="150.0" />
      <Label layoutX="45.0" layoutY="279.0" text="Description of Activities:" />
      <TextArea fx:id="descriptionTextArea" layoutX="181.0" layoutY="247.0" prefHeight="82.0" prefWidth="326.0" />
      <Button layoutX="255.0" layoutY="372.0" mnemonicParsing="false" onAction="#submitButtonOnAction" text="Submit" />
      <Button layoutX="499.0" layoutY="29.0" mnemonicParsing="false" onAction="#backButtonONAction" text="back" />
      <Label fx:id="message" layoutX="396.0" layoutY="122.0" prefHeight="18.0" prefWidth="150.0" text="Label" />
      <Label layoutX="45.0" layoutY="214.0" text="Report Type:" />
      <ComboBox fx:id="reportTypeCombobox" layoutX="136.0" layoutY="210.0" prefWidth="150.0" />
   </children>
</AnchorPane>
