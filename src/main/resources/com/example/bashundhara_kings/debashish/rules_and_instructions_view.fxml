<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="mainpane" prefHeight="474.0" prefWidth="565.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.debashish.RulesAndInstructionsViewController">
   <children>
      <Label layoutX="204.0" layoutY="24.0" text="Rules and Instructions">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Label layoutX="67.0" layoutY="88.0" text="1. General Security Guidelines:" />
      <TextArea layoutX="84.0" layoutY="112.0" prefHeight="70.0" prefWidth="368.0" text="* All personnel must carry valid ID cards at all times&#10;* Unauthorized access to restricted areas is strictly prohibited&#10;* Follow instructions from security supervisors and management&#10;* Report any suspicious activity immediately&#10;" />
      <TextArea layoutX="79.0" layoutY="227.0" prefHeight="56.0" prefWidth="378.0" text="* In case of fire, use nearest emergency exit and avoid panic&#10;* Inform control room or emergency response team immediately&#10;* Provide first aid support if trained&#10;* Follow evacuation plan and assist visitors if needed" />
      <Label layoutX="70.0" layoutY="202.0" text="2. Emergency Procedures:" />
      <Label layoutX="70.0" layoutY="296.0" text="3. Event-Specific Instructions:" />
      <TextArea layoutX="79.0" layoutY="314.0" prefHeight="62.0" prefWidth="350.0" text="* Be aware of match schedule and assigned duty zones&#10;* Monitor VIP areas and player zones carefully&#10;* Ensure crowd control at entry and exit points&#10;* Coordinate with event managers and staff" />
      <Label layoutX="16.0" layoutY="396.0" text="Note:These instructions are fixed and always visible to ensure safety and smooth event management." />
      <Button layoutX="510.0" layoutY="27.0" mnemonicParsing="false" onAction="#backButtonOnAction" text="back" />
   </children>
</AnchorPane>
