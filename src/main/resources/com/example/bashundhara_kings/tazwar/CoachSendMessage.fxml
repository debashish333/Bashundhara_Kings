<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.CoachSendMessageController">
    <children>
        <Label layoutX="190.0" layoutY="30.0" text="Send Message to Players">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="90.0" text="Recipient:" />
        <ComboBox fx:id="recipientCombo" layoutX="260.0" layoutY="86.0" prefWidth="280.0" prefHeight="26.0" promptText="Select Player or Broadcast to All" />

        <Label layoutX="80.0" layoutY="133.0" text="Message Subject:" />
        <TextField fx:id="subjectField" layoutX="260.0" layoutY="129.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter subject" />

        <Label layoutX="80.0" layoutY="180.0" text="Message Body:" />
        <TextArea fx:id="messageArea" layoutX="260.0" layoutY="176.0" prefWidth="280.0" prefHeight="180.0" promptText="Write your message here" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="375.0" prefWidth="460.0" prefHeight="30.0" />

        <Button layoutX="260.0" layoutY="415.0" prefWidth="100.0" prefHeight="27.0" text="Send" onAction="#sendMessage" />
    </children>
</AnchorPane>
