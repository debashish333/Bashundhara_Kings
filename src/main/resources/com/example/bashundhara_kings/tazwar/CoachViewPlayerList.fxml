<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.CoachViewPlayerListController">
    <children>
        <Label layoutX="270.0" layoutY="30.0" text="Player List">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <TableView fx:id="playerTable" layoutX="40.0" layoutY="80.0" prefWidth="670.0" prefHeight="360.0">
            <columns>
                <TableColumn fx:id="playerIdCol" text="Player ID" prefWidth="90.0" />
                <TableColumn fx:id="fullNameCol" text="Full Name" prefWidth="130.0" />
                <TableColumn fx:id="ageCol" text="Age" prefWidth="60.0" />
                <TableColumn fx:id="positionCol" text="Position" prefWidth="110.0" />
                <TableColumn fx:id="contactCol" text="Contact Number" prefWidth="120.0" />
                <TableColumn fx:id="emailCol" text="Email" prefWidth="130.0" />
                <TableColumn fx:id="attendanceCol" text="Attendance Rate (%)" prefWidth="130.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="455.0" prefWidth="560.0" prefHeight="26.0" />

        <Button layoutX="630.0" layoutY="455.0" prefWidth="80.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
