<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerRequestEquipmentController">
    <children>
        <Label layoutX="225.0" layoutY="30.0" text="Request Equipment">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="85.0" text="Available Equipment:" />
        <TableView fx:id="equipmentTable" layoutX="40.0" layoutY="108.0" prefWidth="640.0" prefHeight="230.0">
            <columns>
                <TableColumn fx:id="equipNameCol" text="Equipment Name" prefWidth="180.0" />
                <TableColumn fx:id="categoryCol" text="Category" prefWidth="140.0" />
                <TableColumn fx:id="stockCol" text="Available Stock" prefWidth="130.0" />
                <TableColumn fx:id="maxQtyCol" text="Max Qty Per Request" prefWidth="190.0" />
            </columns>
        </TableView>

        <Label layoutX="40.0" layoutY="355.0" text="Selected Equipment:" />
        <Label fx:id="selectedItemLabel" layoutX="200.0" layoutY="355.0" prefWidth="260.0" />

        <Label layoutX="40.0" layoutY="395.0" text="Requested Quantity:" />
        <TextField fx:id="quantityField" layoutX="200.0" layoutY="391.0" prefWidth="120.0" prefHeight="26.0" promptText="Enter quantity" />

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="440.0" prefWidth="560.0" prefHeight="30.0" />

        <Button layoutX="200.0" layoutY="490.0" prefWidth="120.0" prefHeight="27.0" text="Request" onAction="#submitRequest" />
    </children>
</AnchorPane>
