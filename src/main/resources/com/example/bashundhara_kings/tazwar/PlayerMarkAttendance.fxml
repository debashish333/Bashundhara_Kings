<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="380.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerMarkAttendanceController">
    <children>
        <Label layoutX="195.0" layoutY="40.0" text="Mark Attendance">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="110.0" text="Today's Date:" />
        <Label fx:id="todayDateLabel" layoutX="260.0" layoutY="110.0" prefWidth="240.0" />

        <Label layoutX="80.0" layoutY="155.0" text="Session:" />
        <Label fx:id="sessionLabel" layoutX="260.0" layoutY="155.0" prefWidth="240.0" text="Checking for active session..." />

        <Label layoutX="80.0" layoutY="200.0" text="Attendance Status:" />
        <Label fx:id="eligibilityLabel" layoutX="260.0" layoutY="200.0" prefWidth="240.0" />

        <Button fx:id="presentButton" layoutX="200.0" layoutY="270.0" prefWidth="200.0" prefHeight="35.0" text="Present" onAction="#markPresent" disable="true" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="320.0" prefWidth="440.0" prefHeight="30.0" />
    </children>
</AnchorPane>
