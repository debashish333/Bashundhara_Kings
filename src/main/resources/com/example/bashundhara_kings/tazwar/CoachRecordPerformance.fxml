<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.CoachRecordPerformanceController">
    <children>
        <Label layoutX="170.0" layoutY="30.0" text="Record Player Performance">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="90.0" text="Select Player:" />
        <ComboBox fx:id="playerCombo" layoutX="260.0" layoutY="86.0" prefWidth="240.0" prefHeight="26.0" promptText="Select Player" />

        <Label layoutX="80.0" layoutY="133.0" text="Session Date:" />
        <DatePicker fx:id="sessionDatePicker" layoutX="260.0" layoutY="129.0" prefWidth="240.0" />

        <Label layoutX="80.0" layoutY="176.0" text="Speed Score (1-10):" />
        <TextField fx:id="speedField" layoutX="260.0" layoutY="172.0" prefWidth="240.0" prefHeight="26.0" promptText="Enter score 1-10" />

        <Label layoutX="80.0" layoutY="219.0" text="Endurance Score (1-10):" />
        <TextField fx:id="enduranceField" layoutX="260.0" layoutY="215.0" prefWidth="240.0" prefHeight="26.0" promptText="Enter score 1-10" />

        <Label layoutX="80.0" layoutY="262.0" text="Technique Score (1-10):" />
        <TextField fx:id="techniqueField" layoutX="260.0" layoutY="258.0" prefWidth="240.0" prefHeight="26.0" promptText="Enter score 1-10" />

        <Label layoutX="80.0" layoutY="305.0" text="Teamwork Score (1-10):" />
        <TextField fx:id="teamworkField" layoutX="260.0" layoutY="301.0" prefWidth="240.0" prefHeight="26.0" promptText="Enter score 1-10" />

        <Label layoutX="80.0" layoutY="348.0" text="Coach Comments:" />
        <TextArea fx:id="commentsArea" layoutX="260.0" layoutY="344.0" prefWidth="240.0" prefHeight="80.0" promptText="Enter comments or notes" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="445.0" prefWidth="460.0" prefHeight="30.0" />

        <Button layoutX="260.0" layoutY="490.0" prefWidth="120.0" prefHeight="27.0" text="Save" onAction="#savePerformance" />
    </children>
</AnchorPane>
