<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="780.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.CoachViewAttendanceController">
    <children>
        <Label layoutX="265.0" layoutY="30.0" text="View Player Attendance">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <TableView fx:id="attendanceTable" layoutX="40.0" layoutY="80.0" prefWidth="700.0" prefHeight="350.0">
            <columns>
                <TableColumn fx:id="playerIdCol" text="Player ID" prefWidth="90.0" />
                <TableColumn fx:id="playerNameCol" text="Player Name" prefWidth="130.0" />
                <TableColumn fx:id="sessionDateCol" text="Date of Session" prefWidth="120.0" />
                <TableColumn fx:id="sessionTypeCol" text="Session Type" prefWidth="120.0" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120.0" />
                <TableColumn fx:id="attendancePctCol" text="Attendance %" prefWidth="120.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="445.0" prefWidth="560.0" prefHeight="26.0" />

        <Button layoutX="660.0" layoutY="445.0" prefWidth="80.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
