<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerViewAnnouncementsController">
    <children>
        <Label layoutX="245.0" layoutY="30.0" text="Announcements">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <TableView fx:id="announcementTable" layoutX="40.0" layoutY="80.0" prefWidth="640.0" prefHeight="350.0">
            <columns>
                <TableColumn fx:id="announcementIdCol" text="Announcement ID" prefWidth="130.0" />
                <TableColumn fx:id="titleCol" text="Title" prefWidth="200.0" />
                <TableColumn fx:id="postedDateCol" text="Posted Date" prefWidth="130.0" />
                <TableColumn fx:id="postedByCol" text="Posted By" prefWidth="180.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="445.0" prefWidth="560.0" prefHeight="26.0" />
    </children>
</AnchorPane>
