<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerViewMatchScheduleController">
    <children>
        <Label layoutX="270.0" layoutY="30.0" text="View Match Schedule">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <TableView fx:id="matchTable" layoutX="40.0" layoutY="80.0" prefWidth="740.0" prefHeight="350.0">
            <columns>
                <TableColumn fx:id="matchIdCol" text="Match ID" prefWidth="80.0" />
                <TableColumn fx:id="dateTimeCol" text="Date and Time" prefWidth="130.0" />
                <TableColumn fx:id="opponentCol" text="Opponent Team" prefWidth="130.0" />
                <TableColumn fx:id="venueCol" text="Venue" prefWidth="110.0" />
                <TableColumn fx:id="matchTypeCol" text="Match Type" prefWidth="110.0" />
                <TableColumn fx:id="resultCol" text="Result" prefWidth="180.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="445.0" prefWidth="600.0" prefHeight="26.0" />
    </children>
</AnchorPane>
