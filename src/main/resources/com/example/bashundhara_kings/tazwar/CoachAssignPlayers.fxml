<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.CoachAssignPlayersController">
    <children>
        <Label layoutX="230.0" layoutY="30.0" text="Assign Players to Training Session">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="85.0" text="Upcoming Training Sessions:" />
        <TableView fx:id="sessionTable" layoutX="40.0" layoutY="108.0" prefWidth="670.0" prefHeight="200.0">
            <columns>
                <TableColumn fx:id="sessionIdCol" text="Session ID" prefWidth="90.0" />
                <TableColumn fx:id="sessionDateCol" text="Date and Time" prefWidth="140.0" />
                <TableColumn fx:id="trainingTypeCol" text="Training Type" prefWidth="120.0" />
                <TableColumn fx:id="venueCol" text="Venue" prefWidth="130.0" />
                <TableColumn fx:id="assignedCountCol" text="Assigned Players" prefWidth="110.0" />
            </columns>
        </TableView>

        <Label layoutX="40.0" layoutY="325.0" text="Select Players to Assign (hold Ctrl for multiple):" />
        <ListView fx:id="playerListView" layoutX="40.0" layoutY="348.0" prefWidth="400.0" prefHeight="150.0" />

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="510.0" prefWidth="500.0" prefHeight="26.0" />

        <Button layoutX="460.0" layoutY="430.0" prefWidth="100.0" prefHeight="27.0" text="Assign" onAction="#assignPlayers" />
        <Button layoutX="580.0" layoutY="510.0" prefWidth="80.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
