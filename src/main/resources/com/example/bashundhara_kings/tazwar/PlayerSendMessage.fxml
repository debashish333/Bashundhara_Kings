<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="440.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerSendMessageController">
    <children>
        <Label layoutX="190.0" layoutY="30.0" text="Send Message to Coach">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="90.0" text="Coach Name:" />
        <Label fx:id="coachNameLabel" layoutX="260.0" layoutY="90.0" prefWidth="280.0" />

        <Label layoutX="80.0" layoutY="133.0" text="Message Subject:" />
        <TextField fx:id="subjectField" layoutX="260.0" layoutY="129.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter subject" />

        <Label layoutX="80.0" layoutY="180.0" text="Message Body:" />
        <TextArea fx:id="messageArea" layoutX="260.0" layoutY="176.0" prefWidth="280.0" prefHeight="160.0" promptText="Write your message here" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="355.0" prefWidth="460.0" prefHeight="30.0" />

        <Button layoutX="260.0" layoutY="395.0" prefWidth="100.0" prefHeight="27.0" text="Send" onAction="#sendMessage" />
        <Button layoutX="380.0" layoutY="395.0" prefWidth="70.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
