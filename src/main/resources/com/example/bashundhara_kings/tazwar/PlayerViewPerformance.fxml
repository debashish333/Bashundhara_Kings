<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="480.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerViewPerformanceController">
    <children>
        <Label layoutX="255.0" layoutY="30.0" text="My Personal Performance">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <TableView fx:id="performanceTable" layoutX="40.0" layoutY="80.0" prefWidth="740.0" prefHeight="350.0">
            <columns>
                <TableColumn fx:id="sessionDateCol" text="Session Date" prefWidth="110.0" />
                <TableColumn fx:id="trainingTypeCol" text="Training Type" prefWidth="110.0" />
                <TableColumn fx:id="speedCol" text="Speed Score" prefWidth="100.0" />
                <TableColumn fx:id="enduranceCol" text="Endurance Score" prefWidth="120.0" />
                <TableColumn fx:id="techniqueCol" text="Technique Score" prefWidth="120.0" />
                <TableColumn fx:id="teamworkCol" text="Teamwork Score" prefWidth="120.0" />
                <TableColumn fx:id="commentsCol" text="Coach Comments" prefWidth="160.0" />
            </columns>
        </TableView>

        <Label fx:id="statusLabel" layoutX="40.0" layoutY="445.0" prefWidth="600.0" prefHeight="26.0" />
    </children>
</AnchorPane>
