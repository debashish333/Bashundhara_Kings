<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="580.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bashundhara_kings.tazwar.PlayerUpdateProfileController">
    <children>
        <Label layoutX="195.0" layoutY="30.0" text="Update Personal Profile">
            <font>
                <Font name="Arial Bold Italic" size="23.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="90.0" text="Full Name:" />
        <TextField fx:id="fullNameField" layoutX="260.0" layoutY="86.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter full name" />

        <Label layoutX="80.0" layoutY="133.0" text="Date of Birth:" />
        <DatePicker fx:id="dobPicker" layoutX="260.0" layoutY="129.0" prefWidth="280.0" />

        <Label layoutX="80.0" layoutY="176.0" text="Contact Number:" />
        <TextField fx:id="contactField" layoutX="260.0" layoutY="172.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter 11-digit number" />

        <Label layoutX="80.0" layoutY="219.0" text="Email Address:" />
        <TextField fx:id="emailField" layoutX="260.0" layoutY="215.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter email address" />

        <Label layoutX="80.0" layoutY="262.0" text="Position:" />
        <ComboBox fx:id="positionCombo" layoutX="260.0" layoutY="258.0" prefWidth="280.0" prefHeight="26.0" promptText="Select Position" />

        <Label layoutX="80.0" layoutY="305.0" text="Emergency Contact Name:" />
        <TextField fx:id="emergencyNameField" layoutX="260.0" layoutY="301.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter emergency contact name" />

        <Label layoutX="80.0" layoutY="348.0" text="Emergency Contact Number:" />
        <TextField fx:id="emergencyContactField" layoutX="260.0" layoutY="344.0" prefWidth="280.0" prefHeight="26.0" promptText="Enter emergency contact number" />

        <Label fx:id="statusLabel" layoutX="80.0" layoutY="395.0" prefWidth="460.0" prefHeight="30.0" />

        <Button layoutX="260.0" layoutY="440.0" prefWidth="130.0" prefHeight="27.0" text="Save Changes" onAction="#saveChanges" />
        <Button layoutX="410.0" layoutY="440.0" prefWidth="70.0" prefHeight="27.0" text="Back" onAction="#goBack" />
    </children>
</AnchorPane>
